-- NOCLIP SYSTEM
-- ============================================

local function StopNoClip()
    NoClipConfig.Enabled = false
    RunService:UnbindFromRenderStep("NoClipHack")
    
    local character = LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetChildren()) do
            if part.Name == "LowerTorso" or part.Name == "UpperTorso" or part.Name == "HumanoidRootPart" then
                part.CanCollide = true
            end
        end
    end
    
    print("🛑 NoClip Disabled")
end

local function StartNoClip()
    if NoClipConfig.Enabled then
        StopNoClip()
        return
    end
    
    NoClipConfig.Enabled = true
    
    print("👻 NoClip Enabled")
    
    RunService:BindToRenderStep("NoClipHack", Enum.RenderPriority.Character.Value, function()
        if not NoClipConfig.Enabled then
            RunService:UnbindFromRenderStep("NoClipHack")
            return
        end
        
        local character = LocalPlayer.Character
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function ToggleNoClip()
    if NoClipConfig.Enabled then
        StopNoClip()
    else
        StartNoClip()
    end
end

