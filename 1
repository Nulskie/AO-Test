local OriginalRenderDistance = nil

local function SetRenderDistance(multiplier)
    pcall(function()
        local bin = LocalPlayer:WaitForChild("bin", 5)
        local settingsValue = bin:WaitForChild("Settings", 5)
        
        local settingsJson = settingsValue.Value
        local settings = HttpService:JSONDecode(settingsJson)
        
        if OriginalRenderDistance == nil then
            OriginalRenderDistance = settings[15] or 1
            print("📊 Original Render Distance:", OriginalRenderDistance)
        end
        
        settings[15] = multiplier
        
        local newJson = HttpService:JSONEncode(settings)
        settingsValue.Value = newJson
        
        print("🔧 Render Multiplier:", multiplier)
    end)
end

local function CalculateRenderMultiplier(espDistance)
    local multiplier = math.ceil(espDistance / 4000)
    return math.max(1, multiplier)
end

