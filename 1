-- DEPTH CHECK UTILITY
-- ==================================================================

local function GetDepth(instance, root)
    local depth = 0
    local current = instance
    
    while current and current ~= root and current ~= game do
        depth = depth + 1
        current = current.Parent
        
        if depth > 20 then -- Safety limit
            return 20
        end
    end
    
    return depth
end

local function GetDescendantsWithDepth(root, maxDepth)
    local results = {}
    local queue = {{obj = root, depth = 0}}
    
    while #queue > 0 do
        local current = table.remove(queue, 1)
        local obj = current.obj
        local depth = current.depth
        
        if depth < maxDepth then
            for _, child in ipairs(obj:GetChildren()) do
                table.insert(results, child)
                table.insert(queue, {obj = child, depth = depth + 1})
            end
        end
    end
    
    return results
end

-- ==================================================================
-- GOD MODE & NO FALL DAMAGE SYSTEM (SHARED HOOK)
-- ==================================================================

local originalNamecall = nil
local GodModeEnabled = false
local NoFallDamageEnabled = false

local function DisableDamageHook()
    if originalNamecall and hookmetamethod then
        hookmetamethod(game, "__namecall", originalNamecall)
        originalNamecall = nil
        print("🔧 Damage hook disabled")
    end
end

local function EnableDamageHook()
    if originalNamecall then return end -- Hook already active
    
    originalNamecall = hookmetamethod(game, "__namecall", newcclosure(function(...)
        local args = {...}
        local self = args[1]
        
        local method = getnamecallmethod()
        
        if method == "FireServer" and not checkcaller() then
            -- No Fall Damage check
            if NoFallDamageEnabled and self.Name == "FallDamage" then
                return
            end
            
            -- God Mode checks
            if GodModeEnabled then
                if self.Name == "TouchDamage" then
                    return
                elseif self.Name == "DealBossDamage" then
                    if args[3] == Character then return end
                elseif self.Name == "TakeSideDamage" then
                    return
                elseif self.Name == "DealAttackDamage" then
                    if args[3] == Character then return end
                elseif self.Name == "DealWeaponDamage" then
                    if args[4] == Character then return end
                elseif self.Name == "DealSWDamage" then
                    if args[4] == Character then return end
                elseif self.Name == "DealStrengthDamage" then
                    if args[4] == Character then return end
                elseif self.Name == "DealAnimalDamage" then
                    if args[3] == Character then return end
                end
            end
        end
        
        return originalNamecall(...)
    end))
    
    print("🔧 Damage hook enabled")
end

local function ToggleGodMode()
    GodModeEnabled = not GodModeEnabled
    Config.GodMode.Enabled = GodModeEnabled
    
    if GodModeEnabled then
        EnableDamageHook()
        print("✅ God Mode Enabled")
    else
        print("❌ God Mode Disabled")
        -- Only disable hook if No Fall Damage is also disabled
        if not NoFallDamageEnabled then
            DisableDamageHook()
        end
    end
    
    QueueConfigSave()
end

local function ToggleNoFallDamage()
    NoFallDamageEnabled = not NoFallDamageEnabled
    Config.NoFallDamage.Enabled = NoFallDamageEnabled
    
    if NoFallDamageEnabled then
        EnableDamageHook()
        print("✅ No Fall Damage Enabled")
    else
        print("❌ No Fall Damage Disabled")
        -- Only disable hook if God Mode is also disabled
        if not GodModeEnabled then
            DisableDamageHook()
        end
    end
    
    QueueConfigSave()
end

