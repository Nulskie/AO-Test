local function SilentAutoFish()
    if Config.AutoFish.IsFishing then return end
    Config.AutoFish.IsFishing = true
    
    local rod = nil
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if item:IsA("Tool") and item.Name:find("Rod") then
            rod = item
            break
        end
    end
    
    if not rod and Character then
        for _, item in ipairs(Character:GetChildren()) do
            if item:IsA("Tool") and item.Name:find("Rod") then
                rod = item
                break
            end
        end
    end
    
    if not rod then 
        Config.AutoFish.IsFishing = false
        return 
    end

    if not workspace:FindFirstChild("Effects") then
        local effectsFolder = Instance.new("Folder")
        effectsFolder.Name = "Effects"
        effectsFolder.Parent = workspace
    end

    local hrp = Character:FindFirstChild("HumanoidRootPart")
    if not hrp then 
        Config.AutoFish.IsFishing = false
        return 
    end
    
    local fakeBobber = Instance.new("Part")
    fakeBobber.Name = "Bobber"
    fakeBobber.Size = Vector3.new(2, 2, 2)
    fakeBobber.Anchored = true
    fakeBobber.CanCollide = false
    fakeBobber.Transparency = 1
    fakeBobber.CFrame = hrp.CFrame * CFrame.new(0, -10, 0)
    fakeBobber.Parent = workspace.Effects

    pcall(function()
        ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Misc"):WaitForChild("FishClock"):FireServer(rod, nil, fakeBobber.Position, Config.AutoFish.Bait)
    end)

    task.spawn(function()
        -- Wait for bite (with timeout)
        local timeout = 0
        repeat 
            task.wait(0.1)
            timeout = timeout + 0.1
        until Character:FindFirstChild("FishBiteProgress") or not fakeBobber.Parent or timeout > 90
        
        if Character:FindFirstChild("FishBiteProgress") then
            -- Spam reel until done
            repeat
                pcall(function()
                    ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Misc"):WaitForChild("FishState"):FireServer("Reel")
                end)
                task.wait(0.3)
            until not Character:FindFirstChild("FishClock")
        end
        
        fakeBobber:Destroy()
        
        -- Wait a bit before allowing next session
        task.wait(0.5)
        Config.AutoFish.IsFishing = false
    end)
end

local function AutoFishLoop()
    while Config.AutoFish.Enabled do
        if not Config.AutoFish.IsFishing then
            SilentAutoFish()
        end
        task.wait(0.5) -- Check every 0.5 seconds
    end
end

local function ToggleAutoFish(enabled)
    Config.AutoFish.Enabled = enabled
    
    if Config.AutoFish.Enabled then
        print("Auto Fish Enabled")
        Config.AutoFish.FishingTask = task.spawn(AutoFishLoop)
    else
        print("Auto Fish Disabled")
        Config.AutoFish.IsFishing = false
        if Config.AutoFish.FishingTask then
            task.cancel(Config.AutoFish.FishingTask)
            Config.AutoFish.FishingTask = nil
        end
    end
end

