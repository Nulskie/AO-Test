    if not writefile or not readfile or not isfile or not makefolder or not isfolder then
        warn("⚠️ Your executor doesn't support file functions. Config won't save!")
        return false
    end
    return true
end

local FileSupported = CheckFileSupport()

local function EnsureConfigFolder()
    if not FileSupported then return end
    
    pcall(function()
        if not isfolder(ConfigFolder) then
