local function GetEnemyHealth(enemy)
    local humanoid = enemy:FindFirstChildOfClass("Humanoid")
    if humanoid then return humanoid.Health, humanoid.MaxHealth end
    local healthAttr = enemy:FindFirstChild("Attributes")
    if healthAttr then
        local health = healthAttr:FindFirstChild("Health")
        if health and health:IsA("IntValue") then return health.Value, health.Value end
    end
    return 0, 0
end

local function IsEnemyAlive(enemy)
    local health = GetEnemyHealth(enemy)
    return health > 0
end

