-- ==================================================================

local SeaMonstersESPLastUpdate = 0
local SEA_MONSTERS_UPDATE_INTERVAL = 0.5 -- Update every 0.5 seconds

local function RemoveSeaMonsterESP(monster)
    local data = TrackedSeaMonsters[monster]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    
    TrackedSeaMonsters[monster] = nil
end

local function IsSeaMonsterEnabled(monsterType)
    return Config.SeaMonstersESP.EnabledMonsters[monsterType] == true
end

local function IsSeaMonsterAlive(monster)
    -- Check if Attributes folder exists
    local attributes = monster:FindFirstChild("Attributes")
    if not attributes then return false end
    
    -- Check if Health exists
    local health = attributes:FindFirstChild("Health")
    if not health then return false end
    
    -- Check health value (supports IntValue, NumberValue, or direct Value property)
    local healthValue = 0
    if health:IsA("IntValue") or health:IsA("NumberValue") then
        healthValue = health.Value
    elseif typeof(health) == "number" then
        healthValue = health
    end
    
    return healthValue >= 1
end

local function CreateSeaMonsterESP(monster, monsterType)
    if TrackedSeaMonsters[monster] then return end
    
    -- Find HumanoidRootPart
    local hrp = monster:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local color = Color3.fromRGB(255, 100, 100) -- Red for all sea monsters
    
    -- Create highlight on main model
    local highlight = CreateHighlight(monster, color)
    
    -- Create billboard on HumanoidRootPart
    local billboard, textLabel = CreateBillboardGui(hrp, monsterType, color, 14)
    
    TrackedSeaMonsters[monster] = {
        Highlight = highlight,
        Billboard = billboard,
        TextLabel = textLabel,
        HRP = hrp,
        Type = monsterType
    }
end

local function UpdateSeaMonstersESP()
    if not Config.SeaMonstersESP.Enabled then
        for monster in pairs(TrackedSeaMonsters) do
            RemoveSeaMonsterESP(monster)
        end
        return
    end
    
    -- Throttle updates
    local currentTime = tick()
    if currentTime - SeaMonstersESPLastUpdate < SEA_MONSTERS_UPDATE_INTERVAL then
        return
    end
    SeaMonstersESPLastUpdate = currentTime
    
    if not HumanoidRootPart then return end
    
    -- Find Enemies folder
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return end
    
    -- Scan for sea monsters
    for _, child in ipairs(enemiesFolder:GetChildren()) do
        if child:IsA("Model") and child.Name == "Shark" then
            -- Check for Attributes folder
            local attributes = child:FindFirstChild("Attributes")
            if attributes then
                local sharkType = attributes:FindFirstChild("SharkType")
                if sharkType and sharkType:IsA("StringValue") then
                    local monsterType = sharkType.Value
                    
                    -- Check if alive
                    local isAlive = IsSeaMonsterAlive(child)
                    
                    if not isAlive then
                        -- Dead monster - remove ESP
                        RemoveSeaMonsterESP(child)
                    elseif IsSeaMonsterEnabled(monsterType) then
                        -- Alive and enabled - create/update ESP
                        if not TrackedSeaMonsters[child] then
                            CreateSeaMonsterESP(child, monsterType)
                        else
                            -- Update existing monster distance
                            local data = TrackedSeaMonsters[child]
                            if data.HRP and data.TextLabel then
                                local distance = GetDistance(HumanoidRootPart, data.HRP)
                                data.TextLabel.Text = string.format(
                                    "<font size=\"14\">%s</font>\n<font size=\"12\">%.0f studs</font>",
                                    data.Type,
                                    distance
                                )
                            end
                        end
                    else
                        -- Monster type disabled - remove ESP
                        RemoveSeaMonsterESP(child)
                    end
                end
            end
        end
    end
    
    -- Clean up removed/dead monsters
    for monster in pairs(TrackedSeaMonsters) do
        if not monster.Parent or not IsSeaMonsterAlive(monster) then
            RemoveSeaMonsterESP(monster)
        end
    end
end

local function ToggleSeaMonstersESP(enabled)
    Config.SeaMonstersESP.Enabled = enabled
    
    if enabled then
        print("🦈 Sea Monsters ESP Enabled")
    else
        print("🦈 Sea Monsters ESP Disabled")
        for monster in pairs(TrackedSeaMonsters) do
            RemoveSeaMonsterESP(monster)
        end
    end
end

