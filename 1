-- ==================================================================

local FleetState = "IDLE" -- States: "IDLE", "RECOVERING", "TASK_ACTIVE"
local FleetAutoTaskLastUpdate = 0
local FLEET_UPDATE_INTERVAL = 5 -- Check every 5 seconds

local function GetFleetStrength()
    local bin = LocalPlayer:FindFirstChild("bin")
    if not bin then return 0 end
    
    local fleetValue = bin:FindFirstChild("Fleet")
    if not fleetValue or not fleetValue:IsA("StringValue") then return 0 end
    
    -- Parse JSON
    local success, fleetData = pcall(function()
        return HttpService:JSONDecode(fleetValue.Value)
    end)
    
    if not success or not fleetData then return 0 end
    
    -- Extract Strength from Statistics
    if fleetData.Statistics and fleetData.Statistics.Strength then
        return fleetData.Statistics.Strength
    end
    
    return 0
end

local function SendFleetCommand(taskName)
    for i = 1, 4 do
        pcall(function()
            ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Boats"):WaitForChild("Castaway"):FireServer(
                tostring(i),
                "CommandTask",
                taskName
            )
        end)
        task.wait(0.1) -- Small delay between calls
    end
end

local function UpdateFleetAutoTask()
    if not Config.FleetAutoTask.Enabled then
        FleetState = "IDLE"
        return
    end
    
    -- Throttle updates
    local currentTime = tick()
    if currentTime - FleetAutoTaskLastUpdate < FLEET_UPDATE_INTERVAL then
        return
    end
    FleetAutoTaskLastUpdate = currentTime
    
    local currentStrength = GetFleetStrength()
    
    -- State machine logic
    if currentStrength < Config.FleetAutoTask.RecoverThreshold then
        -- Need to recover
        if FleetState ~= "RECOVERING" then
            print(string.format("🚢 Fleet Strength: %.1f%% (Below %d%%) - Sending Recover commands", currentStrength, Config.FleetAutoTask.RecoverThreshold))
            SendFleetCommand("Recover")
            FleetState = "RECOVERING"
        end
    elseif currentStrength >= 99 then
        -- Strength recovered, send task
        if FleetState ~= "TASK_ACTIVE" then
            print(string.format("🚢 Fleet Strength: %.1f%% - Sending %s commands", currentStrength, Config.FleetAutoTask.SelectedTask))
            SendFleetCommand(Config.FleetAutoTask.SelectedTask)
            FleetState = "TASK_ACTIVE"
        end
    end
end

local function ToggleFleetAutoTask(enabled)
    Config.FleetAutoTask.Enabled = enabled
    
    if enabled then
        print("🚢 Fleet Auto Task & Recover Enabled")
        FleetState = "IDLE" -- Reset state
        FleetAutoTaskLastUpdate = 0 -- Force immediate check
        
        -- Immediately check and fire commands
        task.spawn(function()
            task.wait(0.1) -- Small delay to ensure everything is set
            UpdateFleetAutoTask()
        end)
    else
        print("🚢 Fleet Auto Task & Recover Disabled")
        FleetState = "IDLE"
    end
    
    QueueConfigSave()
end

local function SetFleetTask(taskName)
    Config.FleetAutoTask.SelectedTask = taskName
    
    -- If enabled, immediately fire the new task
    if Config.FleetAutoTask.Enabled then
        local currentStrength = GetFleetStrength()
        
        print(string.format("🚢 Task changed to %s (Current Strength: %.1f%%) - Sending commands immediately", taskName, currentStrength))
        
        if currentStrength >= Config.FleetAutoTask.RecoverThreshold then
            -- Strength is good, send the task immediately
            SendFleetCommand(taskName)
            FleetState = "TASK_ACTIVE"
        else
            -- Strength is low, send recover
            SendFleetCommand("Recover")
            FleetState = "RECOVERING"
        end
    end
    
    QueueConfigSave()
end

local function SetFleetRecoverThreshold(value)
    Config.FleetAutoTask.RecoverThreshold = value
    QueueConfigSave()
end

