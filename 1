		Label.Parent = SliderFrame
		
		-- Value Display
		local ValueLabel = Instance.new("TextLabel")
		ValueLabel.Size = UDim2.new(0, 50, 0, 20)
		ValueLabel.Position = UDim2.new(1, -60, 0, 5)
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.Text = tostring(defaultValue)
		ValueLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
		ValueLabel.Font = Enum.Font.GothamBold
		ValueLabel.TextSize = 12
		ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
		ValueLabel.Parent = SliderFrame
		
		-- Slider Background (Frame)
		local SliderBG = Instance.new("Frame")
		SliderBG.Size = UDim2.new(1, -20, 0, 6)
		SliderBG.Position = UDim2.new(0, 10, 1, -15)
		SliderBG.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
		SliderBG.BorderSizePixel = 0
		SliderBG.Parent = SliderFrame
		
		Instance.new("UICorner", SliderBG).CornerRadius = UDim.new(0, 3)
		
		-- Slider Fill
		local SliderFill = Instance.new("Frame")
		SliderFill.Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
		SliderFill.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
		SliderFill.BorderSizePixel = 0
		SliderFill.Parent = SliderBG
		
		Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(0, 3)
		
		-- Invisible TextButton for interaction (on top of SliderBG)
		local SliderButton = Instance.new("TextButton")
		SliderButton.Size = UDim2.new(1, 0, 1, 0)
		SliderButton.Position = UDim2.new(0, 0, 0, 0)
		SliderButton.BackgroundTransparency = 1
		SliderButton.Text = ""
		SliderButton.Active = true
		SliderButton.Parent = SliderBG
		
		-- Interaction Logic
		local dragging = false
		
		local function UpdateSlider(mouseX)
			local relativeX = math.clamp((mouseX - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
			local value = math.floor(minValue + (maxValue - minValue) * relativeX)
			
			SliderFill.Size = UDim2.new(relativeX, 0, 1, 0)
			ValueLabel.Text = tostring(value)
			
			if callback then
				callback(value)
			end
		end
		
		-- Start dragging when clicked
		SliderButton.MouseButton1Down:Connect(function()
			dragging = true
			local mouse = game:GetService("Players").LocalPlayer:GetMouse()
			UpdateSlider(mouse.X)
		end)
		
		-- Stop dragging globally
		game:GetService("UserInputService").InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)
		
		-- Update while dragging
		game:GetService("RunService").RenderStepped:Connect(function()
			if dragging then
				local mouse = game:GetService("Players").LocalPlayer:GetMouse()
				UpdateSlider(mouse.X)
			end
		end)
		
		-- Update Y offset (50px height + 8px spacing)
		TabYOffsets[tabName] = yOffset + 50 + 8
		
		-- Update canvas size
		parent.CanvasSize = UDim2.new(0, 0, 0, TabYOffsets[tabName] + 5)
		
		return SliderFrame
	end

