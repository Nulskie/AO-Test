local function IsTypingInChat()
    local focusedObject = UserInputService:GetFocusedTextBox()
    return focusedObject ~= nil
end

local BoatSpeedEnabled = false
local BoatRotationEnabled = false

local function GetPlayerBoat()
    local boatName = string.format("%sBoat", LocalPlayer.Name)
    local boat = workspace:FindFirstChild("Boats")
    if boat then
        boat = boat:FindFirstChild(boatName)
        if boat then
            local center = boat:FindFirstChild("Center")
            return boat, center
        end
    end
    return nil, nil
end

local function StopBoatSpeed()
    BoatSpeedEnabled = false
    RunService:UnbindFromRenderStep("BoatSpeedHack")
    print("Boat Speed Disabled")
end

local function StartBoatSpeed()
    local boat, center = GetPlayerBoat()
    if not center then
        warn("No boat found! Cannot enable boat speed.")
        return false
    end
    
    BoatSpeedEnabled = true
    print("Boat Speed Enabled")
    
    RunService:BindToRenderStep("BoatSpeedHack", 0, function()
        if not BoatSpeedEnabled then
            RunService:UnbindFromRenderStep("BoatSpeedHack")
            return
        end
        
        local boat, center = GetPlayerBoat()
        if not center then
            StopBoatSpeed()
            return
        end
        
        local throttle = 0
        if not IsTypingInChat() then
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                throttle = 1
            elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
                throttle = -1
            end
        end
        
        center.Anchored = false
        local cf = center.CFrame
        local desiredLinearVel = cf.LookVector * throttle * Config.BoatSpeed.Speed
        center.AssemblyLinearVelocity = center.AssemblyLinearVelocity:Lerp(desiredLinearVel, 0.13)
    end)
    
    return true
end

local function ToggleBoatSpeed()
    if BoatSpeedEnabled then
        StopBoatSpeed()
        Config.BoatSpeed.Enabled = false
    else
        if StartBoatSpeed() then
            Config.BoatSpeed.Enabled = true
        else
            Config.BoatSpeed.Enabled = false
        end
    end
end

local function StopBoatRotation()
    BoatRotationEnabled = false
    RunService:UnbindFromRenderStep("RotationHack")
    print("Boat Rotation Disabled")
end

local function StartBoatRotation()
    local boat, center = GetPlayerBoat()
    if not center then
        warn("No boat found! Cannot enable boat rotation.")
        return false
    end
    
    BoatRotationEnabled = true
    print("Boat Rotation Enabled")
    
    RunService:BindToRenderStep("RotationHack", 0, function()
        if not BoatRotationEnabled then
            RunService:UnbindFromRenderStep("RotationHack")
            return
        end
        
        local boat, center = GetPlayerBoat()
        if not center then
            StopBoatRotation()
            return
        end
        
        local steer = 0
        if not IsTypingInChat() then
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                steer = Config.BoatRotation.Speed
            elseif UserInputService:IsKeyDown(Enum.KeyCode.A) then
                steer = -Config.BoatRotation.Speed
            end
        end
        
        center.AssemblyAngularVelocity = Vector3.new(0, steer, 0)
    end)
    
    return true
end

local function ToggleBoatRotation()
    if BoatRotationEnabled then
        StopBoatRotation()
        Config.BoatRotation.Enabled = false
    else
        if StartBoatRotation() then
            Config.BoatRotation.Enabled = true
        else
            Config.BoatRotation.Enabled = false
        end
    end
end

