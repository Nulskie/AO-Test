		HeaderButton.Font = Enum.Font.GothamBold
		HeaderButton.TextSize = 11
		HeaderButton.TextXAlignment = Enum.TextXAlignment.Center
		HeaderButton.Active = true
		HeaderButton.Parent = DropdownFrame
		
		Instance.new("UICorner", HeaderButton).CornerRadius = UDim.new(0, 4)
		
		local HeaderPadding = Instance.new("UIPadding", HeaderButton)
		HeaderPadding.PaddingLeft = UDim.new(0, 5)
		HeaderPadding.PaddingRight = UDim.new(0, 5)
		
		-- Get ScreenGui reference for parenting dropdown outside main frame
		local ScreenGui = DropdownFrame:FindFirstAncestorOfClass("ScreenGui")
		
		-- Options Container (parented to ScreenGui so it's not clipped!)
		local OptionsFrame = Instance.new("Frame")
		OptionsFrame.Name = "OptionsFrame_" .. name
		OptionsFrame.Size = UDim2.new(0, 120, 0, math.min(#optionList * 25, 150))
		OptionsFrame.Position = UDim2.new(0, 0, 0, 0)
		OptionsFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
		OptionsFrame.BorderSizePixel = 0
		OptionsFrame.ClipsDescendants = true
		OptionsFrame.Visible = false
		OptionsFrame.ZIndex = 100
		OptionsFrame.Active = true
		OptionsFrame.Parent = ScreenGui
		
		Instance.new("UICorner", OptionsFrame).CornerRadius = UDim.new(0, 4)
		
		-- Scrolling Frame
		local ScrollingFrame = Instance.new("ScrollingFrame")
		ScrollingFrame.Name = "ScrollingFrame"
		ScrollingFrame.Size = UDim2.new(1, 0, 1, 0)
		ScrollingFrame.BackgroundTransparency = 1
		ScrollingFrame.ScrollBarThickness = 4
		ScrollingFrame.BorderSizePixel = 0
		ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, #optionList * 25)
		ScrollingFrame.Active = true
		ScrollingFrame.ScrollingEnabled = true
		ScrollingFrame.ScrollBarImageColor3 = Color3.fromRGB(100, 200, 255)
		ScrollingFrame.Parent = OptionsFrame
		
		-- Create option buttons with MANUAL positioning
		for i, optionText in ipairs(optionList) do
			local OptionButton = Instance.new("TextButton")
			OptionButton.Name = "Option_" .. optionText
			OptionButton.Size = UDim2.new(1, -4, 0, 25)
			OptionButton.Position = UDim2.new(0, 0, 0, (i - 1) * 25)
			OptionButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			OptionButton.BorderSizePixel = 0
			OptionButton.Text = optionText
			OptionButton.TextColor3 = Color3.new(1, 1, 1)
			OptionButton.Font = Enum.Font.GothamBold
			OptionButton.TextSize = 11
			OptionButton.TextXAlignment = Enum.TextXAlignment.Center
			OptionButton.Active = true
			OptionButton.ZIndex = 101
			OptionButton.Parent = ScrollingFrame
			
			-- Hover effect
			OptionButton.MouseEnter:Connect(function()
				OptionButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			end)
			
			OptionButton.MouseLeave:Connect(function()
				OptionButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			end)
			
			-- Click handler
			OptionButton.MouseButton1Click:Connect(function()
				HeaderButton.Text = optionText .. " ▼"
				OptionsFrame.Visible = false
				if callback then callback(optionText) end
			end)
		end
		
		-- Function to update dropdown position
		local function UpdateDropdownPosition()
			local buttonPos = HeaderButton.AbsolutePosition
			local buttonSize = HeaderButton.AbsoluteSize
			
			OptionsFrame.Position = UDim2.new(
				0, buttonPos.X,
				0, buttonPos.Y + buttonSize.Y + 2
			)
		end
		
		-- Toggle dropdown
		HeaderButton.MouseButton1Click:Connect(function()
			OptionsFrame.Visible = not OptionsFrame.Visible
			if OptionsFrame.Visible then
				UpdateDropdownPosition()
			end
		end)
		
		-- Close dropdown when clicking outside
		game:GetService("UserInputService").InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				if OptionsFrame.Visible then
					local mousePos = input.Position
					local optionsPos = OptionsFrame.AbsolutePosition
					local optionsSize = OptionsFrame.AbsoluteSize
					
					-- Check if click is outside dropdown
					if mousePos.X < optionsPos.X or mousePos.X > optionsPos.X + optionsSize.X or
					mousePos.Y < optionsPos.Y or mousePos.Y > optionsPos.Y + optionsSize.Y then
						local buttonPos = HeaderButton.AbsolutePosition
						local buttonSize = HeaderButton.AbsoluteSize
						if mousePos.X < buttonPos.X or mousePos.X > buttonPos.X + buttonSize.X or
						mousePos.Y < buttonPos.Y or mousePos.Y > buttonPos.Y + buttonSize.Y then
							OptionsFrame.Visible = false
						end
					end
				end
			end
		end)
		
		parent:GetPropertyChangedSignal("Visible"):Connect(function()
			if not parent.Visible then
				OptionsFrame.Visible = false
			end
		end)
		
		-- Update Y offset
		TabYOffsets[tabName] = yOffset + 30 + 8
		
		-- Update canvas size
		parent.CanvasSize = UDim2.new(0, 0, 0, TabYOffsets[tabName] + 5)
		
		return DropdownFrame
	end

