local function UpdateEnemyKillAura()
    if not Config.EnemyKillAura.Enabled or not HumanoidRootPart then return end
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return end
    
    for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        local rootPart = enemy:FindFirstChild("HumanoidRootPart")
        if rootPart then
            local distance = GetDistance(HumanoidRootPart, rootPart)
            if distance <= Config.EnemyKillAura.MaxDistance and IsEnemyAlive(enemy) then
                if not TrackedEnemies[enemy] then TrackedEnemies[enemy] = {LastAttack = 0} end
                local currentTime = tick()
                if currentTime - TrackedEnemies[enemy].LastAttack >= Config.EnemyKillAura.AttackDelay then
                    AttackEnemy(enemy)
                    TrackedEnemies[enemy].LastAttack = currentTime
                end
            else
                TrackedEnemies[enemy] = nil
            end
        end
    end
end

-- ============================================
-- BOAT SYSTEM
-- ============================================

local function IsBoatAlive(boat) 
    return boat.Dura.Value ~= 0
end

local function GetBoatColor(boat)
    local flagColor = boat:FindFirstChild("FlagColor")
    if flagColor and flagColor:IsA("Color3Value") then 
        return flagColor.Value 
    end
    return Color3.new(1, 0, 0)
end

local function AttackBoat(boat)
    if not boat.Parent or not IsBoatAlive(boat) then return end
    
    local playerChar = workspace:FindFirstChild(LocalPlayer.Name)
    if not playerChar then return end
    
    local args = {
        [1] = playerChar,
        [2] = boat,
        [3] = "Metal Magic",
        [4] = "3",
        [5] = "[\"Pulsar\", 200,20,20,true,\"Two Hands\",\"25\",\"Pulsar\",\"Drill\",\"Metal\"]",
        [6] = 60
    }
    
    pcall(function()
        ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Magic"):WaitForChild("DealDamageBoat"):FireServer(unpack(args))
    end)
end

local function RemoveBoatESP(boat)
    local data = TrackedBoats[boat]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    
    TrackedBoats[boat] = nil
end

local function UpdateBoatESP(boat)
    if not boat:IsA("Model") then return end
    
    local primaryPart = boat.PrimaryPart or boat:FindFirstChildWhichIsA("BasePart")
    local dura = boat:FindFirstChild("Dura")

    if not primaryPart then return end
    if not dura then return end
    
    local distance = GetDistance(HumanoidRootPart, primaryPart)
    local isAlive = IsBoatAlive(boat)
    local color = GetBoatColor(boat)
    
    if Config.BoatESP.Enabled and isAlive and distance <= Config.BoatESP.MaxDistance then
        if not TrackedBoats[boat] then
            local highlight = CreateHighlight(boat, color)
            local billboard, textLabel = CreateBillboardGui(primaryPart, boat.Name, color, 14)
            TrackedBoats[boat] = {
                Highlight = highlight,
                Billboard = billboard,
                TextLabel = textLabel
            }
        end
        
        if TrackedBoats[boat].TextLabel then
            local displayText
            if Config.BoatESP.ShowBoatType then
                local boatType = boat:FindFirstChild("Type")
                if boatType and boatType:IsA("StringValue") then
                    displayText = string.format('<font size="18">%s | %s</font>\n<font size="14">%.0f studs</font>', boat.Name, boatType.Value, distance)
                else
                    displayText = string.format('<font size="18">%s</font>\n<font size="14">%.0f studs</font>', boat.Name, distance)
                end
            else
                displayText = string.format('<font size="18">%s</font>\n<font size="14">%.0f studs</font>', boat.Name, distance)
            end
            
            TrackedBoats[boat].TextLabel.Text = displayText
        end
    else
        RemoveBoatESP(boat)
    end
    
    if Config.BoatKillAura.Enabled and isAlive and distance <= Config.BoatKillAura.MaxDistance then
        if not TrackedBoats[boat] then
            TrackedBoats[boat] = {}
        end
        
        if not TrackedBoats[boat].LastAttack then
            TrackedBoats[boat].LastAttack = 0
        end
        
        local currentTime = tick()
        if currentTime - TrackedBoats[boat].LastAttack >= Config.BoatKillAura.AttackDelay then
            AttackBoat(boat)
            TrackedBoats[boat].LastAttack = currentTime
        end
    end
    
    if not isAlive then
        RemoveBoatESP(boat)
    end
end

local function UpdateBoats()
    if not HumanoidRootPart then return end
    
    local boatsFolder = workspace:FindFirstChild("Boats")
    if boatsFolder then
        for _, boat in ipairs(boatsFolder:GetChildren()) do
            UpdateBoatESP(boat)
        end
    end
    
    for boat, _ in pairs(TrackedBoats) do
        if not boat.Parent then
            RemoveBoatESP(boat)
        end
    end
end

