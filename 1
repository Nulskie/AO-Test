local AutoRepairTask = nil

local function AutoRepairFleetLoop()
    while Config.AutoRepairFleet.Enabled do
        local success = pcall(function()
            -- Step 1: Invoke repair all
            ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Boats"):WaitForChild("Fleets"):WaitForChild("FleetRepairAll"):InvokeServer()
            
            -- Step 2: Wait for Question GUI
            local playerGui = LocalPlayer:WaitForChild("PlayerGui")
            local timeout = 0
            local questionGui = nil
            
            repeat
                task.wait(0.1)
                timeout = timeout + 0.1
                questionGui = playerGui:FindFirstChild("Question")
            until questionGui or timeout >= 5
            
            if not questionGui then
                warn("Question GUI not found")
                return
            end
            
            -- Step 3: Check Info text
            local frame = questionGui:FindFirstChild("Frame")
            if not frame then
                warn("Frame not found in Question GUI")
                return
            end
            
            local info = frame:FindFirstChild("Info")
            if not info then
                warn("Info not found in Frame")
                return
            end
            
            -- Step 4: Verify text contains repair confirmation
            if info.Text and info.Text:find("Are you sure you want to repair all ships in your fleet for") then
                -- Step 5: Click Accept button
                local acceptButton = frame:FindFirstChild("AcceptButton")
                if acceptButton and acceptButton:IsA("ImageButton") then
                    -- Simulate MouseButton1Up
                    for _, connection in pairs(getconnections(acceptButton.MouseButton1Up)) do
                        connection:Fire()
                    end
                    print("Fleet repair confirmed!")
                else
                    warn("AcceptButton not found or not an ImageButton")
                end
            else
                warn("Repair confirmation text not found")
            end
        end)
        
        if not success then
            warn("Auto Repair Fleet error occurred")
        end
        
        task.wait(180) -- Wait 180 seconds (3 minutes)
    end
end

local function ToggleAutoRepairFleet(enabled)
    Config.AutoRepairFleet.Enabled = enabled
    
    if enabled then
        print("Auto Repair Fleet Enabled")
        if AutoRepairTask then
            task.cancel(AutoRepairTask)
        end
        AutoRepairTask = task.spawn(AutoRepairFleetLoop)
    else
        print("Auto Repair Fleet Disabled")
        if AutoRepairTask then
            task.cancel(AutoRepairTask)
            AutoRepairTask = nil
        end
    end
end

