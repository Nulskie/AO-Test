-- ============================================
-- UTILITY FUNCTIONS
-- ============================================

local function GetDistance(part1, part2)
    if not part1 or not part2 then return math.huge end
    return (part1.Position - part2.Position).Magnitude
end

local function CreateHighlight(parent, color)
    local highlight = Instance.new("Highlight")
    highlight.Adornee = parent
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = parent
    return highlight
end

local function CreateBillboardGui(parent, text, color, fontSize)
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Name = "ESPLabel"
    billboardGui.Adornee = parent
    billboardGui.Size = UDim2.new(0, 200, 0, 50)
    billboardGui.StudsOffset = Vector3.new(0, 3, 0)
    billboardGui.AlwaysOnTop = true
    billboardGui.Parent = parent

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = color
    textLabel.TextStrokeTransparency = 0.5
    textLabel.Font = Enum.Font.GothamBold
    textLabel.RichText = true
    textLabel.TextSize = fontSize or 14
    textLabel.Parent = billboardGui

    return billboardGui, textLabel
end

-- ============================================
-- ITEM ESP SYSTEM (REAGENTS & CATALYSTS)
-- ============================================

local function RemoveItemESP(item)
    local data = ItemESPConfig.TrackedItems[item]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    if data.GhostPart then data.GhostPart:Destroy() end
    
    ItemESPConfig.TrackedItems[item] = nil
end

local function IsItemEnabled(itemName)
    local lowerName = itemName:lower()
    
    -- Check Reagents
    for name, _ in pairs(ItemESPConfig.EnabledReagents) do
        if name:lower() == lowerName then
            return true
        end
    end
    
    -- Check Catalysts
    for name, _ in pairs(ItemESPConfig.EnabledCatalysts) do
        if name:lower() == lowerName then
            return true
        end
    end
    
    -- Check Ingredients (NEW)
    for name, _ in pairs(ItemESPConfig.EnabledIngredients) do
        if name:lower() == lowerName then
            return true
        end
    end
    
    return false
end


local function CreateItemESP(item, itemName, isUnloaded)
    if ItemESPConfig.TrackedItems[item] then return end
    
    local color = Color3.new(1, 1, 1)
    
    local data = {
        Name = itemName,
        IsGhost = isUnloaded
    }
    
    if isUnloaded then
        local ghost = Instance.new("Part")
        ghost.Name = "Ghost_" .. itemName
        ghost.Size = Vector3.new(2, 2, 2)
        ghost.CFrame = item.CFrame
        ghost.Anchored = true
        ghost.CanCollide = false
        ghost.Transparency = 1
        ghost.Parent = GhostFolder
        
        data.GhostPart = ghost
        data.Highlight = CreateHighlight(ghost, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(ghost, itemName, color, 14)
    else
        data.Highlight = CreateHighlight(item, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(item, itemName, color, 14)
    end
    
    ItemESPConfig.TrackedItems[item] = data
end

local function ScanForItems()
    if not ItemESPConfig.Enabled then return end
    if not HumanoidRootPart then return end
    
    local folders = {}
    if workspace:FindFirstChild("Map") then
        table.insert(folders, workspace.Map)
    end
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs and rs:FindFirstChild("UnloadIslands") then
        table.insert(folders, rs.UnloadIslands)
    end
    
    local itemsProcessed = 0
    local SCANBUDGET = 500
    
    for _, folder in ipairs(folders) do
        local isUnloaded = folder.Parent == ReplicatedStorage or folder.Parent.Parent == ReplicatedStorage
        local descendants = GetDescendantsWithDepth(folder, 6) -- MAX DEPTH 6
        
        for _, descendant in ipairs(descendants) do
            if not ItemESPConfig.Enabled then break end
            
            if (descendant:IsA("Part") or descendant:IsA("MeshPart")) and (descendant.Name:find("Herb") or descendant.Name:find("Fruit") or descendant.Name:find("Fruits")) then
                local prompt = descendant:FindFirstChildOfClass("ProximityPrompt")
                if prompt and prompt.ObjectText then
                    local itemName = prompt.ObjectText
                    if IsItemEnabled(itemName) then
                        if not ItemESPConfig.TrackedItems[descendant] then
                            CreateItemESP(descendant, itemName, isUnloaded)
                        end
                    end
                end
            end
            
            itemsProcessed = itemsProcessed + 1
            if itemsProcessed >= SCANBUDGET then
                itemsProcessed = 0
                task.wait()
            end
        end
        
        if not ItemESPConfig.Enabled then break end
    end
end

local function TryCollectItem(item, data)
    if not Config.ItemESP.AutoCollect then return end
    if not HumanoidRootPart then return end
    if data.IsGhost then return end -- Can't collect unloaded items
    
    local distance = GetDistance(HumanoidRootPart, item)
    if distance <= 15 then
        local prompt = item:FindFirstChildOfClass("ProximityPrompt")
        if prompt then
            pcall(function()
                fireproximityprompt(prompt)
            end)
        end
    end
end

local function UpdateItemESPVisuals()
    if not ItemESPConfig.Enabled then
        for item in pairs(ItemESPConfig.TrackedItems) do
            RemoveItemESP(item)
        end
        return
    end
    
    for item, data in pairs(ItemESPConfig.TrackedItems) do
        if not item.Parent then
            RemoveItemESP(item)
            continue
        end
        
        if not IsItemEnabled(data.Name) then
            RemoveItemESP(item)
            continue
        end
        
        local targetPart = data.IsGhost and data.GhostPart or item
        local distance = GetDistance(HumanoidRootPart, targetPart)
        
        if data.TextLabel then
            data.TextLabel.Text = string.format("<font size=\"14\">%s</font>\n<font size=\"12\">%.0f studs</font>", data.Name, distance)
        end
        
        -- Auto Collect
        TryCollectItem(item, data)
    end
end

local function ToggleItemESP(enabled)
    ItemESPConfig.Enabled = enabled
    
    -- Update UI immediately BEFORE heavy scanning
    if UIToggles and UIToggles.ItemESP then
        UpdateToggleButton(UIToggles.ItemESP, ItemESPConfig.Enabled)
    end
    
    if enabled then
        print("Item ESP Enabled")
        -- Scan in background so it doesn't block UI
        task.spawn(function()
            ScanForItems()
        end)
    else
        print("Item ESP Disabled")
        for item in pairs(ItemESPConfig.TrackedItems) do
            RemoveItemESP(item)
        end
    end
end

-- ==================================================================
-- CHEST ESP SYSTEM WITH DEPTH CHECK & AUTO OPEN (OPTIMIZED)
-- ==================================================================

local ChestAutoOpenCooldowns = {} -- Track cooldowns per chest

local function IsChestValid(chest)
    if not chest:IsA("Model") then return false end
    if not chest.Name:find("Chest") then return false end
    
    local base = chest:FindFirstChild("Base")
    if not base or not base:IsA("MeshPart") then return false end
    if chest:FindFirstChild("Open") then return false end
    
    return true, base
end

local function GetChestColor(base)
    local prompt = base:FindFirstChild("Prompt")
    if prompt and prompt:FindFirstChild("ActionColor") and prompt.ActionColor:IsA("Color3Value") then
        return prompt.ActionColor.Value
    end
    return Color3.new(1, 1, 1)
end

local function ShouldTrackChest(chestName, distance)
    local tier = Config.ChestESP.TierFilter[chestName]
    if chestName == "Mystic Chest" or chestName == "Legendary Chest" then
        return true
    end
    if tier and distance <= Config.ChestESP.MaxDistance then
        return true
    end
    return false
end

local function RemoveChestESP(chest)
    local data = TrackedChests[chest]
    if not data then return end
    
    if data.Highlight then 
        pcall(function() data.Highlight:Destroy() end)
    end
    if data.Billboard then 
        pcall(function() data.Billboard:Destroy() end)
    end
    if data.GhostPart then 
        pcall(function() data.GhostPart:Destroy() end)
    end
    
    TrackedChests[chest] = nil
    ChestAutoOpenCooldowns[chest] = nil
end

local function AddChestESP(chest)
    if TrackedChests[chest] then return end
    
    local isValid, base = IsChestValid(chest)
    if not isValid then return end
    
    local color = GetChestColor(base)
    local isUnloaded = not chest:IsDescendantOf(workspace)
    
    local data = {
        Base = base,
        Color = color,
        IsGhost = isUnloaded
    }
    
    if isUnloaded then
        local ghost = Instance.new("Part")
        ghost.Name = "Ghost_" .. chest.Name
        ghost.Size = Vector3.new(4, 4, 4)
        ghost.CFrame = base.CFrame
        ghost.Anchored = true
        ghost.CanCollide = false
        ghost.Transparency = 1
        ghost.Parent = GhostFolder
        
        data.GhostPart = ghost
        data.Highlight = CreateHighlight(ghost, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(ghost, chest.Name, color, 16)
    else
        data.Highlight = CreateHighlight(chest, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(base, chest.Name, color, 16)
    end
    
    TrackedChests[chest] = data
end

-- Auto Open Chests with proper cooldown
local function TryOpenChest(chest)
    if not Config.ChestESP.AutoOpen then return end
    if not HumanoidRootPart then return end
    
    local data = TrackedChests[chest]
    if not data or not data.Base then return end
    
    -- Check cooldown (prevent spam)
    local currentTime = tick()
    if ChestAutoOpenCooldowns[chest] and (currentTime - ChestAutoOpenCooldowns[chest] < 0.1) then
        return -- 3 second cooldown per chest
    end
    
    local distance = GetDistance(HumanoidRootPart, data.Base)
    if distance <= 20 then
        ChestAutoOpenCooldowns[chest] = currentTime
        
        task.spawn(function()
            local success = pcall(function()
                ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Misc"):WaitForChild("OpenChest"):FireServer(chest)
            end)
            if success then
                print("📦 Opened chest: " .. chest.Name)
            end
        end)
    end
end

local ChestVisualsUpdateDebounce = 0

local function UpdateTrackedChestsVisuals()
    if not Config.ChestESP.Enabled then
        -- Cleanup gradually to prevent freeze
        local chestsToRemove = {}
        for chest in pairs(TrackedChests) do
            table.insert(chestsToRemove, chest)
        end
        
        task.spawn(function()
            for i, chest in ipairs(chestsToRemove) do
                RemoveChestESP(chest)
                if i % 10 == 0 then -- Yield every 10 chests
                    task.wait()
                end
            end
        end)
        return
    end
    
    -- Throttle ONLY when Auto Open is enabled (not the entire function!)
    local shouldCheckAutoOpen = false
    if Config.ChestESP.AutoOpen then
        local currentTime = tick()
        if currentTime - ChestVisualsUpdateDebounce >= 0.5 then
            ChestVisualsUpdateDebounce = currentTime
            shouldCheckAutoOpen = true
        end
    end
    
    for chest, data in pairs(TrackedChests) do
        if not chest.Parent or chest:FindFirstChild("Open") then
            RemoveChestESP(chest)
            continue
        end
        
        local isNowUnloaded = not chest:IsDescendantOf(workspace)
        if data.IsGhost ~= isNowUnloaded then
            RemoveChestESP(chest)
            AddChestESP(chest)
            continue
        end
        
        local targetPart = data.IsGhost and data.GhostPart or data.Base
        local distance = GetDistance(HumanoidRootPart, targetPart)
        
        if data.TextLabel then
            data.TextLabel.Text = string.format("<font size=\"16\">%s</font>\n<font size=\"12\">%.0f studs</font>", chest.Name, distance)
        end
        
        if not ShouldTrackChest(chest.Name, distance) then
            RemoveChestESP(chest)
            continue
        end
        
        -- Auto Open (only check when throttle allows it)
        if shouldCheckAutoOpen then
            TryOpenChest(chest)
        end
    end
end

-- Chest ESP with Recursive Event Detection
local ChestScanDebounce = 0
local ScannedFolders = {}

local function SetupChestDetection(folder, currentDepth)
    currentDepth = currentDepth or 0
    if currentDepth > 6 then return end -- Max depth limit
    if not folder or ScannedFolders[folder] then return end
    
    ScannedFolders[folder] = true
    
    -- Listen for new chests in THIS folder
    folder.ChildAdded:Connect(function(child)
        if not Config.ChestESP.Enabled then return end
        
        task.wait(0.1) -- Wait for chest to fully load
        
        -- If it's a chest, add ESP
        if child:IsA("Model") and child.Name:find("Chest") then
            task.spawn(function()
                local isValid, base = IsChestValid(child)
                if isValid and HumanoidRootPart then
                    local distance = GetDistance(HumanoidRootPart, base)
                    if ShouldTrackChest(child.Name, distance) then
                        AddChestESP(child)
                    end
                end
            end)
        end
        
        -- If it's a folder, set up detection on it too (recursive)
        if child:IsA("Folder") or child:IsA("Model") then
            SetupChestDetection(child, currentDepth + 1)
        end
    end)
    
    -- Recursively set up on existing children
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("Folder") or child:IsA("Model") then
            SetupChestDetection(child, currentDepth + 1)
        end
    end
end

-- Initial chest scan (still use GetDescendants but smarter)
local function QuickScanExistingChests()
    if not Config.ChestESP.Enabled or not HumanoidRootPart then return end
    
    local folders = {}
    if workspace:FindFirstChild("Map") then
        table.insert(folders, workspace.Map)
    end
    if workspace:FindFirstChild("Boats") then
        table.insert(folders, workspace.Boats)
    end
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs and rs:FindFirstChild("UnloadIslands") then
        table.insert(folders, rs.UnloadIslands)
    end
    
    -- Process in batches to avoid freeze
    task.spawn(function()
        for _, folder in ipairs(folders) do
            local chests = {}
            
            -- Collect chest models only
            for _, descendant in ipairs(folder:GetDescendants()) do
                if descendant:IsA("Model") and descendant.Name:find("Chest") then
                    table.insert(chests, descendant)
                end
            end
            
            -- Process them in parallel
            for i, chest in ipairs(chests) do
                if not Config.ChestESP.Enabled then break end
                
                task.spawn(function()
                    if not TrackedChests[chest] then
                        local isValid, base = IsChestValid(chest)
                        if isValid then
                            local distance = GetDistance(HumanoidRootPart, base)
                            if ShouldTrackChest(chest.Name, distance) then
                                AddChestESP(chest)
                            end
                        end
                    end
                end)
                
                -- Yield every 20 chests
                if i % 20 == 0 then
                    task.wait()
                end
            end
        end
    end)
end

-- Main loop
task.spawn(function()
    while true do
        if Config.ChestESP.Enabled then
            local currentTime = tick()
            
            if currentTime - ChestScanDebounce < 10 then
                task.wait(1)
                continue
            end
            ChestScanDebounce = currentTime
            
            -- Set up recursive event detection
            if workspace:FindFirstChild("Map") then
                SetupChestDetection(workspace.Map)
            end
            if workspace:FindFirstChild("Boats") then
                SetupChestDetection(workspace.Boats)
            end
            local rs = ReplicatedStorage:FindFirstChild("RS")
            if rs and rs:FindFirstChild("UnloadIslands") then
                SetupChestDetection(rs.UnloadIslands)
            end
            
            -- Scan for existing chests
            QuickScanExistingChests()
        else
            ScannedFolders = {} -- Reset when disabled
        end
        
        task.wait(2)
    end
end)

-- ============================================
-- LOST CARGO & SEALED CHEST ESP
-- ============================================

local function RemoveTemporaryItemESP(item, trackingTable)
    local data = trackingTable[item]
    if not data then return end
    
    if data.Highlight then
        data.Highlight:Destroy()
    end
    if data.Billboard then
        data.Billboard:Destroy()
    end
    trackingTable[item] = nil
end

local function AddTemporaryItemESP(item, itemType, trackingTable)
    if trackingTable[item] then return end
    
    local color
    if itemType == "Lost Cargo" then
        color = Color3.fromRGB(255, 200, 0)  -- Gold
    elseif itemType == "Bronze Sealed Chest" then
        color = Color3.fromRGB(205, 127, 50)
	elseif itemType == "Nimbus Sealed Chest" then
        color = Color3.fromRGB(135, 206, 250)  
    elseif itemType == "Dark Sealed Chest" then
        color = Color3.fromRGB(128, 0, 128)  -- Purple
    else
        color = Color3.new(1, 1, 1)
    end
    
    local highlight = CreateHighlight(item, color)
    local billboard, textLabel = CreateBillboardGui(item, itemType, color, 14)
    
    trackingTable[item] = {
        Highlight = highlight,
        Billboard = billboard,
        TextLabel = textLabel,
        Type = itemType
    }
end

local function IsLostCargo(itemName)
    return itemName:find("Lost Cargo") ~= nil or itemName:find("lost cargo") ~= nil
end

local function IsSealedChest(itemName)
    return itemName == "Bronze Sealed Chest" or itemName == "Nimbus Sealed Chest" or itemName == "Dark Sealed Chest"
end

local function UpdateTemporaryItemsESP()
    if not HumanoidRootPart then return end
    
    local temporaryFolder = workspace:FindFirstChild("Map")
    if temporaryFolder then
        temporaryFolder = temporaryFolder:FindFirstChild("Temporary")
    end
    
    if not temporaryFolder then return end
    
    -- Scan for items
    for _, item in ipairs(temporaryFolder:GetDescendants()) do
        if (item:IsA("Part") or item:IsA("MeshPart")) and item.Name then
            local itemName = item.Name
            local distance = GetDistance(HumanoidRootPart, item)
            
            -- Check Lost Cargo
            if Config.LostCargoESP.Enabled and IsLostCargo(itemName) then
                if not TrackedLostCargo[item] then
                    AddTemporaryItemESP(item, itemName, TrackedLostCargo)
                end
            end
            
            -- Check Bronze Sealed Chest (shares distance with Nimbus)
            if itemName == "Bronze Sealed Chest" and Config.BronzeSealedChestESP.Enabled then
                if distance <= Config.BronzeSealedChestESP.MaxDistance then
                    if not TrackedSealedChests[item] then
                        AddTemporaryItemESP(item, "Bronze Sealed Chest", TrackedSealedChests)
                    end
                else
                    if TrackedSealedChests[item] and TrackedSealedChests[item].Type == "Bronze Sealed Chest" then
                        RemoveTemporaryItemESP(item, TrackedSealedChests)
                    end
                end
            end
            
            -- ✅ ADD THIS BLOCK - Check Nimbus Sealed Chest (shares distance with Bronze)
            if itemName == "Nimbus Sealed Chest" and Config.NimbusSealedChestESP.Enabled then
                if distance <= Config.BronzeSealedChestESP.MaxDistance then  -- Uses Bronze's MaxDistance
                    if not TrackedSealedChests[item] then
                        AddTemporaryItemESP(item, "Nimbus Sealed Chest", TrackedSealedChests)
                    end
                else
                    if TrackedSealedChests[item] and TrackedSealedChests[item].Type == "Nimbus Sealed Chest" then
                        RemoveTemporaryItemESP(item, TrackedSealedChests)
                    end
                end
            end
            
            -- Check Dark Sealed Chest (with distance check)
            if itemName == "Dark Sealed Chest" and Config.DarkSealedChestESP.Enabled then
                if distance <= Config.DarkSealedChestESP.MaxDistance then
                    if not TrackedSealedChests[item] then
                        AddTemporaryItemESP(item, "Dark Sealed Chest", TrackedSealedChests)
                    end
                else
                    if TrackedSealedChests[item] and TrackedSealedChests[item].Type == "Dark Sealed Chest" then
                        RemoveTemporaryItemESP(item, TrackedSealedChests)
                    end
                end
            end
        end
    end
    
    -- Update distances for Lost Cargo
    for item, data in pairs(TrackedLostCargo) do
        if not item.Parent or not Config.LostCargoESP.Enabled then
            RemoveTemporaryItemESP(item, TrackedLostCargo)
        else
            local distance = GetDistance(HumanoidRootPart, item)
            if data.TextLabel then
                data.TextLabel.Text = string.format('<font size="14">%s</font>\n<font size="12">%.0f studs</font>', data.Type, distance)
            end
        end
    end
    
    -- Update distances for Sealed Chests
    for item, data in pairs(TrackedSealedChests) do
        if not item.Parent then
            RemoveTemporaryItemESP(item, TrackedSealedChests)
        else
            local itemName = item.Name
            local distance = GetDistance(HumanoidRootPart, item)
            
            -- Check if enabled and within range
            local shouldShow = false
            if itemName == "Bronze Sealed Chest" and Config.BronzeSealedChestESP.Enabled then
                shouldShow = distance <= Config.BronzeSealedChestESP.MaxDistance
            elseif itemName == "Nimbus Sealed Chest" and Config.NimbusSealedChestESP.Enabled then  -- ✅ ADD THIS
                shouldShow = distance <= Config.BronzeSealedChestESP.MaxDistance  -- Uses Bronze's MaxDistance
            elseif itemName == "Dark Sealed Chest" and Config.DarkSealedChestESP.Enabled then
                shouldShow = distance <= Config.DarkSealedChestESP.MaxDistance
            end
            
            if not shouldShow then
                RemoveTemporaryItemESP(item, TrackedSealedChests)
            else
                if data.TextLabel then
                    data.TextLabel.Text = string.format('<font size="14">%s</font>\n<font size="12">%.0f studs</font>', data.Type, distance)
                end
            end
        end
    end
end

