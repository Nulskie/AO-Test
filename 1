    pcall(function()
        ReplicatedStorage.RS.Remotes.Magic.DealAttackDamage:FireServer(unpack(args))
        --game:GetService("ReplicatedStorage").RS.Remotes.Combat.DealStrengthDamage:FireServer(unpack(meleeArgs))
