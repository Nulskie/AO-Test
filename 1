local FogRemovalActive = false
local DayNightCycleScript = nil

local function GetDayNightCycleScript()
    if DayNightCycleScript and DayNightCycleScript.Parent then
        return DayNightCycleScript
    end
    
    local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
    if playerScripts then
        DayNightCycleScript = playerScripts:FindFirstChild("DayNightCycle")
        return DayNightCycleScript
    end
    return nil
end

local function EnableFogRemoval()
    local script = GetDayNightCycleScript()
    if not script then
        warn("DayNightCycle script not found!")
        return false
    end
    
    script.Enabled = false
    
    -- Apply bright lighting
    local Light = game:GetService("Lighting")
    
	delay(5, function()
		Light.ClockTime = 12
        Light.FogEnd = 0
        Light.FogStart = 0
        Light.Atmosphere.Density = 0
        Light.Atmosphere.Glare = 0
        Light.Atmosphere.Haze = 0
	end)
    FogRemovalActive = true
    print("Fog Removal Enabled")
    return true
end

local function DisableFogRemoval()
    local script = GetDayNightCycleScript()
    if script then
        script.Enabled = true
    end
    
    FogRemovalActive = false
    print("Fog Removal Disabled")
end

local function ToggleFogRemoval()
    if FogRemovalActive then
        DisableFogRemoval()
        Config.RemoveFog.Enabled = false
    else
        if EnableFogRemoval() then
            Config.RemoveFog.Enabled = true
        else
            Config.RemoveFog.Enabled = false
        end
    end
end

