                    local button = frame:FindFirstChild("ItemToggleBtn")
                    
                    if itemLabel and button then
                        local itemName = itemLabel.Text
                        if ItemESPConfig.EnabledCatalysts[itemName] then
                            button.Text = "ON"
                            button.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
                        end
                    end
                end
            end
        end
        
        print("✅ Settings restored!")
    end)
end

