local function StopFlying()
    Config.Fly.Enabled = false
    RunService:UnbindFromRenderStep("HackFly")
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        
        if humanoid then
            humanoid.PlatformStand = false
        end
        
        if rootPart then
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end
    end
    
    print("🛑 Fly Disabled")
end

local function StartFlying()
    if Config.Fly.Enabled then
        StopFlying()
        return
    end
    
    Config.Fly.Enabled = true
    
    local character = LocalPlayer.Character
    if not character then
        warn("No character found!")
        Config.Fly.Enabled = false
        return
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not rootPart or not humanoid then
        warn("Missing Humanoid or HumanoidRootPart!")
        Config.Fly.Enabled = false
        return
    end
    
    print("✈️ Fly Enabled")
    
    RunService:BindToRenderStep("HackFly", Enum.RenderPriority.Character.Value, function()
        if not Config.Fly.Enabled then
            RunService:UnbindFromRenderStep("HackFly")
            return
        end
        
        local character = LocalPlayer.Character
        if not character then return end
        
        local humanoid = character:FindFirstChild("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        
        if not rootPart or not humanoid then
            StopFlying()
            return
        end
        
        humanoid.PlatformStand = true
        rootPart.Anchored = false
        
        local camera = workspace.CurrentCamera
        local direction = Vector3.new(0, 0, 0)
        
        if not IsTypingInChat() then
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                direction = direction + camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                direction = direction - camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                direction = direction - camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                direction = direction + camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                direction = direction + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                direction = direction + Vector3.new(0, -1, 0)
            end
        end
        
        if direction.Magnitude > 0 then
            direction = direction.Unit * Config.Fly.Speed
            rootPart.AssemblyLinearVelocity = direction
        else
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 3.5, 0)
        end
        
        rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + camera.CFrame.LookVector)
    end)
end

local function ToggleFly()
    if Config.Fly.Enabled then
        StopFlying()
    else
        StartFlying()
    end
end

local function SetFlySpeed(speed)
    Config.Fly.Speed = speed
	QueueConfigSave()
end

