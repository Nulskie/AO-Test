local function GetHelewysePearlStock(npc)
    local shopItems = npc:FindFirstChild("Attributes")
    if not shopItems then return 0, 0 end
    
    shopItems = shopItems:FindFirstChild("ShopItems")
    if not shopItems then return 0, 0 end
    
    local pearlStock = 0
    local goldenPearlStock = 0
    
    for _, item in ipairs(shopItems:GetChildren()) do
        if item:IsA("StringValue") then
            local itemData = item.Value
            local stock = item:FindFirstChild("Stock")
            
            if stock and stock:IsA("IntValue") and stock.Value > 0 then
                if itemData == '{"Amount":1,"Name":"Pearl"}' then
                    pearlStock = stock.Value
                elseif itemData == '{"Amount":1,"Name":"Golden pearl"}' then
                    goldenPearlStock = stock.Value
                end
            end
        end
    end
    
    return pearlStock, goldenPearlStock
end

local function FindHelewysaNPC()
    -- Check ReplicatedStorage first (unloaded)
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs then
        local unloadNPCs = rs:FindFirstChild("UnloadNPCs")
        if unloadNPCs then
            local helewyse = unloadNPCs:FindFirstChild("Helewyse")
            if helewyse then
                return helewyse, "ReplicatedStorage"
            end
        end
    end
    
    -- Check workspace (loaded)
    local npcs = workspace:FindFirstChild("NPCs")
    if npcs then
        local helewysaHolder = npcs:FindFirstChild("Helewyse")
        if helewysaHolder then
            local actualNPC = helewysaHolder:FindFirstChild("Helewyse")
            if actualNPC then
                return actualNPC, "Workspace"
            end
            -- Return holder if actual NPC not loaded yet
            return helewysaHolder, "Holder"
        end
    end
    
    return nil, nil
end

local function WaitForHelewysaInWorkspace()
    local timeout = 0
    repeat
        task.wait(0.5)
        timeout = timeout + 0.5
        
        local npcs = workspace:FindFirstChild("NPCs")
        if npcs then
            local helewysaHolder = npcs:FindFirstChild("Helewyse")
            if helewysaHolder then
                local actualNPC = helewysaHolder:FindFirstChild("Helewyse")
                if actualNPC then
                    return actualNPC
                end
            end
        end
    until timeout >= 30 -- 30 second timeout
    
    return nil
end

local function BuyPearlsFromHelewase()
    if Config.AutoBuyPearls.IsBuying then return end
    Config.AutoBuyPearls.IsBuying = true
    
    task.spawn(function()
        -- Save original position
        if not HumanoidRootPart then
            Config.AutoBuyPearls.IsBuying = false
            return
        end
        
        local originalPosition = HumanoidRootPart.CFrame
        
        -- Find NPC
        local npc, location = FindHelewysaNPC()
        if not npc then
            print("❌ Helewyse NPC not found")
            Config.AutoBuyPearls.IsBuying = false
            return
        end
        
        -- Check stock
        local pearlStock, goldenPearlStock = GetHelewysePearlStock(npc)
        
        if pearlStock == 0 and goldenPearlStock == 0 then
            print("ℹ️ Helewyse has no Pearls in stock")
            Config.AutoBuyPearls.IsBuying = false
            return
        end
        
        print(string.format("🛒 Found Pearls! Pearl: %d, Golden Pearl: %d", pearlStock, goldenPearlStock))
        
        -- Teleport to NPC
        local npcPosition
        if location == "ReplicatedStorage" or location == "Holder" then
            -- Get holder position
            local holder = game:GetService("ReplicatedStorage").RS.UnloadNPCs
            if holder then
                holder = holder:FindFirstChild("Helewyse")
                if holder and holder:FindFirstChild("HumanoidRootPart") then
                    npcPosition = holder.HumanoidRootPart.CFrame
                end
            end
        else
            -- Already in workspace
            if npc:FindFirstChild("HumanoidRootPart") then
                npcPosition = npc.HumanoidRootPart.CFrame
            end
        end
        
        if not npcPosition then
            print("❌ Cannot find NPC position")
            Config.AutoBuyPearls.IsBuying = false
            return
        end
        
        -- TP under the NPC
        ToggleNoClip()
        HumanoidRootPart.CFrame = npcPosition * CFrame.new(0, -8, 0)
        wait(0.1)
        HumanoidRootPart.Anchored = true
        print("📍 Teleported to Helewyse")
        
        task.wait(1)
        
        -- Wait for NPC to be in workspace
        local actualNPC = WaitForHelewysaInWorkspace()
        if not actualNPC then
            print("❌ Helewyse did not load in time")
            HumanoidRootPart.CFrame = originalPosition
            Config.AutoBuyPearls.IsBuying = false
            return
        end
        
        print("✅ Helewyse loaded, starting purchase...")
        
        -- Buy loop
        local boughtCount = 0
        repeat
            local currentPearlStock, currentGoldenPearlStock = GetHelewysePearlStock(actualNPC)
            
            -- Buy Golden Pearl
            if currentGoldenPearlStock > 0 then
                local success = pcall(function()
                    ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Misc"):WaitForChild("BuyItem"):InvokeServer(
                        actualNPC,
                        '{"Amount":1,"Name":"Golden pearl"}',
                        ""
                    )
                end)
                if success then
                    boughtCount = boughtCount + 1
                    print("✅ Bought Golden Pearl")
                end
            end
            
            -- Buy Pearl
            if currentPearlStock > 0 then
                local success = pcall(function()
                    ReplicatedStorage:WaitForChild("RS"):WaitForChild("Remotes"):WaitForChild("Misc"):WaitForChild("BuyItem"):InvokeServer(
                        actualNPC,
                        '{"Amount":1,"Name":"Pearl"}',
                        ""
                    )
                end)
                if success then
                    boughtCount = boughtCount + 1
                    print("✅ Bought Pearl")
                end
            end
            
            -- Refresh stock
            currentPearlStock, currentGoldenPearlStock = GetHelewysePearlStock(actualNPC)
            wait(0.1)
        until (currentPearlStock == 0 and currentGoldenPearlStock == 0) or not actualNPC.Parent
        
        print(string.format("🎉 Finished! Bought %d items total", boughtCount))
        
        -- Teleport back
        HumanoidRootPart.Anchored = false
        wait(0.1)
        HumanoidRootPart.CFrame = originalPosition
        ToggleNoClip()
        HumanoidRootPart.Anchored = true
        wait(8)
        HumanoidRootPart.Anchored = false
        print("📍 Teleported back to original position")
        
        Config.AutoBuyPearls.IsBuying = false
    end)
end

local function UpdateAutoBuyPearls()
    if not Config.AutoBuyPearls.Enabled or Config.AutoBuyPearls.IsBuying then return end
    
    local currentTime = tick()
    if currentTime - Config.AutoBuyPearls.LastCheck < Config.AutoBuyPearls.CheckInterval then
        return
    end
    Config.AutoBuyPearls.LastCheck = currentTime
    
    -- Check if pearls are available
    local npc, location = FindHelewysaNPC()
    if npc then
        local pearlStock, goldenPearlStock = GetHelewysePearlStock(npc)
        if pearlStock > 0 or goldenPearlStock > 0 then
            BuyPearlsFromHelewase()
        end
    end
end

local function ToggleAutoBuyPearls(enabled)
    Config.AutoBuyPearls.Enabled = enabled
    
    if enabled then
        print("🛒 Auto Buy Pearls Enabled - Will check every 20 seconds")
        Config.AutoBuyPearls.LastCheck = 0 -- Force immediate check
    else
        print("🛒 Auto Buy Pearls Disabled")
    end
    
    QueueConfigSave()
end

