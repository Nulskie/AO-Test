    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    
    TrackedDarkSeaEnemies[enemy] = nil
end

local function UpdateDarkSeaEnemiesESP()
    if not Config.DarkSea.EnemiesESP or not HumanoidRootPart then
        for enemy in pairs(TrackedDarkSeaEnemies) do
            RemoveDarkSeaEnemyESP(enemy)
        end
        return
    end
    
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return end
    
    for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        local rootPart = enemy:FindFirstChild("HumanoidRootPart")
        if rootPart then
            local distance = GetDistance(HumanoidRootPart, rootPart)
            local isAlive = IsEnemyAlive(enemy)
            
            if distance <= Config.DarkSea.EnemiesMaxDistance and isAlive then
                if not TrackedDarkSeaEnemies[enemy] then
                    local color = Color3.fromRGB(255, 50, 50) -- Red
                    local highlight = CreateHighlight(enemy, color)
                    local billboard, textLabel = CreateBillboardGui(rootPart, enemy.Name, color, 14)
                    
                    TrackedDarkSeaEnemies[enemy] = {
                        Highlight = highlight,
                        Billboard = billboard,
                        TextLabel = textLabel
                    }
                end
                
                if TrackedDarkSeaEnemies[enemy].TextLabel then
                    TrackedDarkSeaEnemies[enemy].TextLabel.Text = string.format('<font size="14">%s</font>\n<font size="12">%.0f studs</font>', enemy.Name, distance)
                end
            else
                RemoveDarkSeaEnemyESP(enemy)
            end
        end
    end
    
    -- Clean up destroyed enemies
    for enemy in pairs(TrackedDarkSeaEnemies) do
        if not enemy.Parent or not IsEnemyAlive(enemy) then
            RemoveDarkSeaEnemyESP(enemy)
        end
    end
end

-- ==================================================================
-- DARK SEA ITEMS ESP WITH DEPTH CHECK & AUTO COLLECT
-- ==================================================================

local DarkSeaItemsScanTimer = 0

local function ScanDarkSeaItems()
    if not Config.DarkSea.ItemsESP or not HumanoidRootPart then return end
    
    local folders = {}
    local darkSeaFolder = workspace:FindFirstChild("Map")
    if darkSeaFolder then
        darkSeaFolder = darkSeaFolder:FindFirstChild("SeaContent")
        if darkSeaFolder then
            darkSeaFolder = darkSeaFolder:FindFirstChild("DarkSea")
            if darkSeaFolder then
                table.insert(folders, darkSeaFolder)
            end
        end
    end
    
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs then
        local unloadDarkSea = rs:FindFirstChild("UnloadDarkSea")
        if unloadDarkSea then
            table.insert(folders, unloadDarkSea)
        end
    end
    
    local itemsProcessed = 0
    local SCANBUDGET = 500
    
    for _, folder in ipairs(folders) do
        local isUnloaded = folder.Parent == ReplicatedStorage or folder.Parent.Parent == ReplicatedStorage
        local descendants = GetDescendantsWithDepth(folder, 6) -- MAX DEPTH 6
        
        for _, descendant in ipairs(descendants) do
            if not Config.DarkSea.ItemsESP then break end
            
            if (descendant:IsA("Part") or descendant:IsA("MeshPart")) and descendant.Name:find("Herb") then
                local prompt = descendant:FindFirstChildOfClass("ProximityPrompt")
                if prompt and prompt.ObjectText then
                    local itemName = prompt.ObjectText
                    if IsItemEnabled(itemName) then
                        local distance = GetDistance(HumanoidRootPart, descendant)
                        if distance <= Config.DarkSea.ItemsMaxDistance then
                            if not TrackedDarkSeaItems[descendant] then
                                CreateDarkSeaItemESP(descendant, itemName, isUnloaded)
                            end
                        end
                    end
                end
            end
            
            itemsProcessed = itemsProcessed + 1
            if itemsProcessed >= SCANBUDGET then
                itemsProcessed = 0
                task.wait()
            end
        end
        
        if not Config.DarkSea.ItemsESP then break end
    end
end

local function TryCollectDarkSeaItem(item, data)
    if not Config.DarkSea.AutoCollectItems then return end
    if not HumanoidRootPart then return end
    if data.IsGhost then return end
    
    local distance = GetDistance(HumanoidRootPart, item)
    if distance <= 15 then
        local prompt = item:FindFirstChildOfClass("ProximityPrompt")
        if prompt then
            pcall(function()
                fireproximityprompt(prompt)
            end)
        end
    end
end

local function UpdateDarkSeaItemsVisuals()
    if not Config.DarkSea.ItemsESP then
        for item in pairs(TrackedDarkSeaItems) do
            RemoveDarkSeaItemESP(item)
        end
        return
    end
    
    -- Re-scan every 3 seconds (fixes the not detecting new items issue)
    local currentTime = tick()
    if currentTime - DarkSeaItemsScanTimer >= 3 then
        DarkSeaItemsScanTimer = currentTime
        task.spawn(ScanDarkSeaItems)
    end
    
    for item, data in pairs(TrackedDarkSeaItems) do
        if not item.Parent then
            RemoveDarkSeaItemESP(item)
            continue
        end
        
        if not IsItemEnabled(data.Name) then
            RemoveDarkSeaItemESP(item)
            continue
        end
        
        local targetPart = data.IsGhost and data.GhostPart or item
        local distance = GetDistance(HumanoidRootPart, targetPart)
        
        if distance > Config.DarkSea.ItemsMaxDistance then
            RemoveDarkSeaItemESP(item)
            continue
        end
        
        if data.TextLabel then
            data.TextLabel.Text = string.format("<font size=\"14\">%s</font>\n<font size=\"12\">%.0f studs</font>", data.Name, distance)
        end
        
        -- Auto Collect
        TryCollectDarkSeaItem(item, data)
    end
end

