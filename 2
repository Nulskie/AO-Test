local function RemoveCastawayESP(castaway)
    local data = TrackedCastaways[castaway]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    if data.GhostPart then data.GhostPart:Destroy() end
    
    TrackedCastaways[castaway] = nil
end

local function UpdateCastawayESP()
    if not Config.CastawayESP.Enabled or not HumanoidRootPart then
        for castaway in pairs(TrackedCastaways) do
            RemoveCastawayESP(castaway)
        end
        return
    end
    
    local folders = {}
    
    -- workspace.Enemies
    local workspaceEnemies = workspace:FindFirstChild("Enemies")
    if workspaceEnemies then
        table.insert(folders, workspaceEnemies)
    end
    
    -- ReplicatedStorage.RS.UnloadEnemies
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs then
        local unloadEnemies = rs:FindFirstChild("UnloadEnemies")
        if unloadEnemies then
            table.insert(folders, unloadEnemies)
        end
    end
    
    for _, folder in ipairs(folders) do
        local isUnloaded = folder.Parent == ReplicatedStorage or folder.Parent.Parent == ReplicatedStorage
        
        for _, npc in ipairs(folder:GetChildren()) do
            local attributes = npc:FindFirstChild("Attributes")
            if attributes then
                local job = attributes:FindFirstChild("Job")
                if job and job:IsA("StringValue") and job.Value == "Castaway_Base" then
                    local rootPart = npc:FindFirstChild("HumanoidRootPart")
                    
                    if rootPart then
                        local distance = GetDistance(HumanoidRootPart, rootPart)
                        
                        if distance <= Config.CastawayESP.MaxDistance then
                            if not TrackedCastaways[npc] then
                                local color = Color3.fromRGB(100, 200, 255) -- Light blue
                                local data = {IsGhost = isUnloaded}
                                
                                if isUnloaded then
                                    local ghost = Instance.new("Part")
                                    ghost.Name = "GhostCastaway"
                                    ghost.Size = Vector3.new(4, 6, 4)
                                    ghost.CFrame = rootPart.CFrame
                                    ghost.Anchored = true
                                    ghost.CanCollide = false
                                    ghost.Transparency = 1
                                    ghost.Parent = GhostFolder
                                    
                                    data.GhostPart = ghost
                                    data.Highlight = CreateHighlight(ghost, color)
                                    data.Billboard, data.TextLabel = CreateBillboardGui(ghost, "Castaway", color, 14)
                                else
                                    data.Highlight = CreateHighlight(npc, color)
                                    data.Billboard, data.TextLabel = CreateBillboardGui(rootPart, "Castaway", color, 14)
                                end
                                
                                TrackedCastaways[npc] = data
                            end
                            
                            -- Update distance
                            if TrackedCastaways[npc].TextLabel then
                                TrackedCastaways[npc].TextLabel.Text = string.format('<font size="14">Castaway</font>\n<font size="12">%.0f studs</font>', distance)
                            end
                        else
                            RemoveCastawayESP(npc)
                        end
                    end
                end
            end
        end
    end
    
    -- Clean up removed NPCs
    for npc in pairs(TrackedCastaways) do
        if not npc.Parent then
            RemoveCastawayESP(npc)
        end
    end
end

