local function RemoveHecateEssenceESP(essence)
    local data = TrackedHecateEssences[essence]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    if data.GhostPart then data.GhostPart:Destroy() end
    
    TrackedHecateEssences[essence] = nil
end

local function CreateRainbowColor()
    local hue = (tick() % 5) / 5 -- Cycles through rainbow every 5 seconds
    return Color3.fromHSV(hue, 1, 1)
end

local function CreateHecateEssenceESP(essence, isUnloaded)
    if TrackedHecateEssences[essence] then return end
    
    local color = CreateRainbowColor()
    local data = {IsGhost = isUnloaded}
    
    if isUnloaded then
        local ghost = Instance.new("Part")
        ghost.Name = "GhostHecateEssence"
        ghost.Size = Vector3.new(3, 3, 3)
        ghost.CFrame = essence.CFrame
        ghost.Anchored = true
        ghost.CanCollide = false
        ghost.Transparency = 1
        ghost.Parent = GhostFolder
        
        data.GhostPart = ghost
        data.Highlight = CreateHighlight(ghost, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(ghost, "Hecate Essence", color, 16)
    else
        data.Highlight = CreateHighlight(essence, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(essence, "Hecate Essence", color, 16)
    end
    
    TrackedHecateEssences[essence] = data
end

local function ScanHecateEssences()
    if not Config.DarkSea.HecateEssenceESP or not HumanoidRootPart then return end
    
    local folders = {}
    
    -- workspace.Map.SeaContent.DarkSea
    local darkSeaFolder = workspace:FindFirstChild("Map")
    if darkSeaFolder then
        darkSeaFolder = darkSeaFolder:FindFirstChild("SeaContent")
        if darkSeaFolder then
            darkSeaFolder = darkSeaFolder:FindFirstChild("DarkSea")
            if darkSeaFolder then
                table.insert(folders, {Folder = darkSeaFolder, IsUnloaded = false})
            end
        end
    end
    
    -- ReplicatedStorage.RS.UnloadDarkSea
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs then
        local unloadDarkSea = rs:FindFirstChild("UnloadDarkSea")
        if unloadDarkSea then
            table.insert(folders, {Folder = unloadDarkSea, IsUnloaded = true})
        end
    end
    
    local itemsProcessed = 0
    local SCANBUDGET = 200 -- Fast chunk scan
    
    for _, folderData in ipairs(folders) do
        local folder = folderData.Folder
        local isUnloaded = folderData.IsUnloaded
        
        for _, descendant in ipairs(folder:GetDescendants()) do
            if not Config.DarkSea.HecateEssenceESP then break end
            
            if (descendant:IsA("Part") or descendant:IsA("MeshPart")) and descendant.Name == "HecateEssence" then
                if not TrackedHecateEssences[descendant] then
                    CreateHecateEssenceESP(descendant, isUnloaded)
                end
            end
            
            itemsProcessed = itemsProcessed + 1
            if itemsProcessed >= SCANBUDGET then
                itemsProcessed = 0
                task.wait()
            end
        end
        
        if not Config.DarkSea.HecateEssenceESP then break end
    end
end

local function UpdateHecateEssenceVisuals()
    if not Config.DarkSea.HecateEssenceESP then
        for essence in pairs(TrackedHecateEssences) do
            RemoveHecateEssenceESP(essence)
        end
        return
    end
    
    for essence, data in pairs(TrackedHecateEssences) do
        if not essence.Parent then
            RemoveHecateEssenceESP(essence)
            continue
        end
        
        -- Update rainbow color
        local rainbowColor = CreateRainbowColor()
        if data.Highlight then
            data.Highlight.FillColor = rainbowColor
            data.Highlight.OutlineColor = rainbowColor
        end
        if data.TextLabel then
            data.TextLabel.TextColor3 = rainbowColor
        end
        
        -- Update position and distance
        local targetPart = data.IsGhost and data.GhostPart or essence
        
        if data.IsGhost and data.GhostPart then
            data.GhostPart.CFrame = essence.CFrame
        end
        
        local distance = GetDistance(HumanoidRootPart, targetPart)
        
        if data.TextLabel then
            data.TextLabel.Text = string.format('<font size="16">Hecate Essence</font>\n<font size="14">%.0f studs</font>', distance)
        end
    end
end

local function ToggleHecateEssenceESP(enabled)
    Config.DarkSea.HecateEssenceESP = enabled
    
    if enabled then
        print("Hecate Essence ESP Enabled")
        task.spawn(function()
            ScanHecateEssences()
        end)
    else
        print("Hecate Essence ESP Disabled")
        for essence in pairs(TrackedHecateEssences) do
            RemoveHecateEssenceESP(essence)
        end
    end
