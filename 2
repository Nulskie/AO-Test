-- ==================================================================

local TowersESPLastUpdate = 0
local TOWERS_UPDATE_INTERVAL = 1 -- Update every 1 second instead of every frame
local TowersBeingCreated = {} -- Track towers currently being processed

local function RemoveTowerESP(tower)
    local data = TrackedTowers[tower]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    
    TrackedTowers[tower] = nil
    TowersBeingCreated[tower] = nil
end

local function GetRandomPartFromModel(model)
    local parts = {}
    
    -- OPTIMIZED: Stop after finding 20 parts to avoid scanning huge models
    local count = 0
    for _, descendant in ipairs(model:GetDescendants()) do
        if descendant:IsA("Part") or descendant:IsA("MeshPart") then
            table.insert(parts, descendant)
            count = count + 1
            if count >= 20 then break end
        end
    end
    
    if #parts > 0 then
        return parts[math.random(1, #parts)]
    end
    
    return nil
end

local function FindFirstPhysicalPart(model)
    -- OPTIMIZED: Return immediately when found
    for _, child in ipairs(model:GetDescendants()) do
        if child:IsA("Part") or child:IsA("MeshPart") then
            return child
        end
    end
    return nil
end

local function CreateTowerESPAsync(tower)
    if TrackedTowers[tower] or TowersBeingCreated[tower] then return end
    
    TowersBeingCreated[tower] = true
    
    -- Run in separate thread to prevent freezing
    task.spawn(function()
        -- Check if status exists and is valid
        local status = tower:FindFirstChild("Status")
        if not status or not status:IsA("StringValue") then 
            TowersBeingCreated[tower] = nil
            return 
        end
        
        local statusValue = status.Value
        if statusValue ~= "Untouched" and statusValue ~= "Attacked" then 
            TowersBeingCreated[tower] = nil
            return 
        end
        
        -- Yield to next frame before heavy work
        task.wait()
        
        -- Check if still enabled
        if not Config.TowersESP.Enabled then 
            TowersBeingCreated[tower] = nil
            return 
        end
        
        -- Get a random part for the billboard
        local randomPart = GetRandomPartFromModel(tower)
        if not randomPart then 
            TowersBeingCreated[tower] = nil
            return 
        end
        
        -- Find reference part for distance
        local referencePart = FindFirstPhysicalPart(tower)
        if not referencePart then 
            TowersBeingCreated[tower] = nil
            return 
        end
        
        -- Color based on status
        local color = Color3.fromRGB(255, 100, 100) -- Red for attacked
        if statusValue == "Untouched" then
            color = Color3.fromRGB(50, 255, 50) -- Green for untouched
        end
        
        -- Create highlight on main model
        local highlight = CreateHighlight(tower, color)
        
        -- Create billboard on random part
        local billboard, textLabel = CreateBillboardGui(randomPart, "Tower [" .. statusValue .. "]", color, 14)
        
        TrackedTowers[tower] = {
            Highlight = highlight,
            Billboard = billboard,
            TextLabel = textLabel,
            RandomPart = randomPart,
            ReferencePart = referencePart,
            Status = statusValue
        }
        
        TowersBeingCreated[tower] = nil
    end)
end

local function UpdateTowersESP()
    if not Config.TowersESP.Enabled then
        for tower in pairs(TrackedTowers) do
            RemoveTowerESP(tower)
        end
        for tower in pairs(TowersBeingCreated) do
            TowersBeingCreated[tower] = nil
        end
        return
    end
    
    -- OPTIMIZED: Throttle updates to once per second
    local currentTime = tick()
    if currentTime - TowersESPLastUpdate < TOWERS_UPDATE_INTERVAL then
        return
    end
    TowersESPLastUpdate = currentTime
    
    if not HumanoidRootPart then return end
    
    -- Find EnemyTowerSpawns folder
    local towerSpawnsFolder = workspace:FindFirstChild("Map")
    if towerSpawnsFolder then
        towerSpawnsFolder = towerSpawnsFolder:FindFirstChild("SeaContent")
        if towerSpawnsFolder then
            towerSpawnsFolder = towerSpawnsFolder:FindFirstChild("EnemyTowerSpawns")
        end
    end
    
    if not towerSpawnsFolder then return end
    
    -- Scan for tower Models
    for _, child in ipairs(towerSpawnsFolder:GetChildren()) do
        if child:IsA("Model") then
            local status = child:FindFirstChild("Status")
            if status and status:IsA("StringValue") then
                local statusValue = status.Value
                
                if statusValue == "Untouched" or statusValue == "Attacked" then
                    -- Create ESP asynchronously if not exists
                    if not TrackedTowers[child] and not TowersBeingCreated[child] then
                        CreateTowerESPAsync(child)
                    elseif TrackedTowers[child] then
                        -- Update existing tower distance
                        local data = TrackedTowers[child]
                        if data.ReferencePart and data.TextLabel then
                            local distance = GetDistance(HumanoidRootPart, data.ReferencePart)
                            data.TextLabel.Text = string.format(
                                "<font size=\"14\">Tower [%s]</font>\n<font size=\"12\">%.0f studs</font>",
                                data.Status,
                                distance
                            )
                        end
                    end
                else
                    -- Status changed to destroyed or other - remove ESP
                    RemoveTowerESP(child)
                end
            end
        end
    end
    
    -- Clean up removed towers
    for tower in pairs(TrackedTowers) do
        if not tower.Parent then
            RemoveTowerESP(tower)
        end
    end
end

local function ToggleTowersESP(enabled)
    Config.TowersESP.Enabled = enabled
    
    if enabled then
        print("🗼 Towers ESP Enabled")
    else
        print("🗼 Towers ESP Disabled")
        for tower in pairs(TrackedTowers) do
            RemoveTowerESP(tower)
        end
        for tower in pairs(TowersBeingCreated) do
            TowersBeingCreated[tower] = nil
        end
    end
end

