local function RemovePlayerESP(player)
    local data = TrackedPlayers[player]
    if data then
        if data.Highlight then 
            data.Highlight:Destroy() 
        end
        if data.Billboard then 
            data.Billboard:Destroy() 
        end
        -- CRITICAL FIX: Disconnect the CharacterAdded connection
        if data.Connection then
            data.Connection:Disconnect()
        end
        TrackedPlayers[player] = nil
    end
end

local function AddPlayerESP(player)
    if player == LocalPlayer or TrackedPlayers[player] then return end
    
    -- ✅ FIX: Initialize TrackedPlayers FIRST
    TrackedPlayers[player] = {}
    
    local function SetupESP(char)
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        -- Clean up old ESP before creating new one
        if TrackedPlayers[player].Highlight then
            TrackedPlayers[player].Highlight:Destroy()
        end
        if TrackedPlayers[player].Billboard then
            TrackedPlayers[player].Billboard:Destroy()
        end
        
        local hl = CreateHighlight(char, Color3.new(1, 1, 0))
        local bb, txt = CreateBillboardGui(root, player.Name, Color3.new(1, 1, 0), 14)
        
        -- ✅ FIX: Now TrackedPlayers[player] exists, so we can store references
        TrackedPlayers[player].Highlight = hl
        TrackedPlayers[player].Billboard = bb
        TrackedPlayers[player].TextLabel = txt
        TrackedPlayers[player].RootPart = root
    end
    
    -- Initial setup
    if player.Character then
        SetupESP(player.Character)
    end
    
    -- Store the connection so we can disconnect it later
    local connection = player.CharacterAdded:Connect(function(c)
        task.wait(0.5)
        if TrackedPlayers[player] then -- Only setup if still tracking
            SetupESP(c)
        end
    end)
    
    -- ✅ FIX: Store connection AFTER initialization
    TrackedPlayers[player].Connection = connection
end

local function UpdatePlayerESP()
    -- 1. If ESP is disabled, clear everyone and stop
    if not Config.PlayerESP.Enabled then
        for p in pairs(TrackedPlayers) do
            RemovePlayerESP(p)
        end
        return
    end

    -- 2. Update existing players or add new ones
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local char = p.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local dist = GetDistance(HumanoidRootPart, char.HumanoidRootPart)
                
                if dist <= Config.PlayerESP.MaxDistance then
                    if not TrackedPlayers[p] then
                        AddPlayerESP(p)
                    end
                    
                    if TrackedPlayers[p] and TrackedPlayers[p].TextLabel then
                        TrackedPlayers[p].TextLabel.Text = string.format("<font size='18'>%s</font>\n<font size='14'>%.0f studs</font>", p.Name, dist)
                    end
                else
                    -- Remove if they get too far away
                    RemovePlayerESP(p)
                end
            end
        end
    end

    -- 3. Remove players who left the server
    for p, _ in pairs(TrackedPlayers) do
        if not p or not p.Parent or not Players:FindFirstChild(p.Name) then
            RemovePlayerESP(p)
        end
    end
end

