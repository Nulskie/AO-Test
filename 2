local function RemoveDarkSeaLocationESP(location)
    local data = TrackedDarkSeaLocations[location]
    if not data then return end
    
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    if data.GhostPart then data.GhostPart:Destroy() end
    
    TrackedDarkSeaLocations[location] = nil
end

local function CreateDarkSeaLocationESP(location, forcedUnloadedState)
    if TrackedDarkSeaLocations[location] then return end
    
    local center = location:FindFirstChild("Center")
    if not center then return end
    
    local color = Color3.fromRGB(255, 255, 0) -- Yellow
    
    -- ✅ Use forced state (based on distance check in scan)
    local isUnloaded = forcedUnloadedState
    
    local data = {Name = location.Name, IsGhost = isUnloaded}
    
    if isUnloaded then
        local ghost = Instance.new("Part")
        ghost.Name = "Ghost" .. location.Name
        ghost.Size = Vector3.new(10, 10, 10)
        ghost.CFrame = center.CFrame
        ghost.Anchored = true
        ghost.CanCollide = false
        ghost.Transparency = 1
        ghost.Parent = GhostFolder
        
        data.GhostPart = ghost
        data.Highlight = CreateHighlight(ghost, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(ghost, location.Name, color, 16)
    else
        data.Highlight = CreateHighlight(location, color)
        data.Billboard, data.TextLabel = CreateBillboardGui(center, location.Name, color, 16)
        data.Center = center
    end
    
    TrackedDarkSeaLocations[location] = data
end

local function ScanDarkSeaLocations()
    if not Config.DarkSea.LocationsESP or not HumanoidRootPart then return end
    
    local STREAM_DISTANCE = 4000 -- ✅ Distance threshold (adjust if needed)
    
    local folders = {}
    
    -- workspace.Map.SeaContent.DarkSea
    local darkSeaFolder = workspace:FindFirstChild("Map")
    if darkSeaFolder then
        darkSeaFolder = darkSeaFolder:FindFirstChild("SeaContent")
        if darkSeaFolder then
            darkSeaFolder = darkSeaFolder:FindFirstChild("DarkSea")
            if darkSeaFolder then
                table.insert(folders, {Folder = darkSeaFolder, InWorkspace = true})
            end
        end
    end
    
    -- ReplicatedStorage.RS.UnloadDarkSea
    local rs = ReplicatedStorage:FindFirstChild("RS")
    if rs then
        local unloadDarkSea = rs:FindFirstChild("UnloadDarkSea")
        if unloadDarkSea then
            table.insert(folders, {Folder = unloadDarkSea, InWorkspace = false})
        end
    end
    
    for _, folderData in ipairs(folders) do
        local folder = folderData.Folder
        local inWorkspace = folderData.InWorkspace
        
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("Model") and child:FindFirstChild("Center") then
                if not TrackedDarkSeaLocations[child] then
                    local center = child:FindFirstChild("Center")
                    
                    -- ✅ Calculate distance
                    local distance = GetDistance(HumanoidRootPart, center)
                    
                    -- ✅ Decide: if in workspace but FAR, treat as unloaded (create ghost)
                    local shouldCreateGhost = false
                    
                    if inWorkspace then
                        -- In workspace but far = will be streamed out soon, create ghost
                        shouldCreateGhost = distance > STREAM_DISTANCE
                    else
                        -- In ReplicatedStorage = always ghost
                        shouldCreateGhost = true
                    end
                    
                    CreateDarkSeaLocationESP(child, shouldCreateGhost)
                end
            end
        end
    end
end

local function UpdateDarkSeaLocationsVisuals()
    if not Config.DarkSea.LocationsESP then
        for location in pairs(TrackedDarkSeaLocations) do
            RemoveDarkSeaLocationESP(location)
        end
        return
    end
    
    local STREAM_DISTANCE = 4000 -- Same as scan
    
    for location, data in pairs(TrackedDarkSeaLocations) do
        if not location.Parent then
            RemoveDarkSeaLocationESP(location)
            continue
        end
        
        local center = location:FindFirstChild("Center")
        if not center then
            RemoveDarkSeaLocationESP(location)
            continue
        end
        
        local distance = GetDistance(HumanoidRootPart, center)
        local isInWorkspace = location:IsDescendantOf(workspace)
        
        -- ✅ Check if we need to recreate ESP due to streaming
        local shouldBeGhost = (not isInWorkspace) or (isInWorkspace and distance > STREAM_DISTANCE)
        
        if data.IsGhost ~= shouldBeGhost then
            -- State changed! Recreate ESP
            RemoveDarkSeaLocationESP(location)
            CreateDarkSeaLocationESP(location, shouldBeGhost)
            continue
        end
        
        -- ✅ Update ghost position if needed
        if data.IsGhost and data.GhostPart then
            data.GhostPart.CFrame = center.CFrame
        end
        
        local targetPart = data.IsGhost and data.GhostPart or center
        
        if data.TextLabel then
            data.TextLabel.Text = string.format('<font size="16">%s</font>\n<font size="12">%.0f studs</font>', data.Name, distance)
        end
    end
end

-- Start scanning loop
task.spawn(function()
    while true do
        if Config.DarkSea.LocationsESP then
            ScanDarkSeaLocations()
        end
        task.wait(1) -- Scan every 3 seconds
    end
end)

