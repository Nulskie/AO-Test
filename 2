UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F1 then
        Config.ChestESP.Enabled = not Config.ChestESP.Enabled
        if UIToggles.ChestESP then
            UpdateToggleButton(UIToggles.ChestESP, Config.ChestESP.Enabled)
        end
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.F2 then
        Config.EnemyKillAura.Enabled = not Config.EnemyKillAura.Enabled
        if UIToggles.EnemyKillAura then
            UpdateToggleButton(UIToggles.EnemyKillAura, Config.EnemyKillAura.Enabled)
        end
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.F3 then
        Config.BoatKillAura.Enabled = not Config.BoatKillAura.Enabled
        if UIToggles.BoatKillAura then
            UpdateToggleButton(UIToggles.BoatKillAura, Config.BoatKillAura.Enabled)
        end
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.F4 then
        ToggleBoatESP(not Config.BoatESP.Enabled)
        if UIToggles.BoatESP then
            UpdateToggleButton(UIToggles.BoatESP, Config.BoatESP.Enabled)
        end
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.F5 then
        Config.PlayerESP.Enabled = not Config.PlayerESP.Enabled
        if UIToggles.PlayerESP then
            UpdateToggleButton(UIToggles.PlayerESP, Config.PlayerESP.Enabled)
        end
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.F6 then
        ToggleFly()
        if UIToggles.Fly then
            UpdateToggleButton(UIToggles.Fly, Config.Fly.Enabled)
        end
    elseif input.KeyCode == Enum.KeyCode.F7 then
        ToggleNoClip()
        if UIToggles.NoClip then
            UpdateToggleButton(UIToggles.NoClip, NoClipConfig.Enabled)
        end
    elseif input.KeyCode == Enum.KeyCode.F8 then
		ToggleGodMode()
		task.wait(0.1) -- Small delay for state to update
		if UIToggles.GodMode then
			UpdateToggleButton(UIToggles.GodMode, GodModeEnabled)
		end
    elseif input.KeyCode == Enum.KeyCode.F9 then
        ToggleMoneyFarm()
        if UIToggles.MoneyFarm then
            UpdateToggleButton(UIToggles.MoneyFarm, MoneyFarmConfig.Enabled)
        end
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.F10 then
        ToggleItemESP(not ItemESPConfig.Enabled)
        QueueConfigSave()
    elseif input.KeyCode == Enum.KeyCode.RightControl then
        local gui = LocalPlayer.PlayerGui:FindFirstChild("FarmESPGui")
        if gui and gui:FindFirstChild("MainFrame") then
            gui.MainFrame.Visible = not gui.MainFrame.Visible
        end
    end
end)

